# =============================================================================
# kellylaura.art — environment configuration
# Copy this file to .env.local and fill in real values for whichever providers
# you're flipping from mock → real.
# =============================================================================

# --- Site -------------------------------------------------------------------
# Public origin (used in metadata, sitemap, OG, emails). Vercel auto-injects
# VERCEL_URL on preview/prod, but explicit SITE_URL is preferred.
# Production: SITE_URL=https://kellylaura.art
SITE_URL=http://localhost:3000

# --- Provider switches ------------------------------------------------------
# mock = in-memory + console (dev-friendly, no external accounts required)
# Real values: PAYMENT_PROVIDER=stripe, EMAIL_PROVIDER=resend, SANITY_MODE=live
PAYMENT_PROVIDER=mock
EMAIL_PROVIDER=mock
SANITY_MODE=mock

# --- Sanity (only used when SANITY_MODE=live) -------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
# Read token: anonymous read is fine for public content; use a token to bypass
# CDN or read drafts.
SANITY_API_READ_TOKEN=
# Write token: required for the inventory reservation patches & inquiry writes.
SANITY_API_WRITE_TOKEN=
# Shared secret used by Sanity webhook → /api/revalidate
SANITY_REVALIDATE_SECRET=

# --- Stripe (only used when PAYMENT_PROVIDER=stripe) ------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (only used when EMAIL_PROVIDER=resend) --------------------------
RESEND_API_KEY=
RESEND_FROM_ADDRESS="Kelly Laura <contact@kellylaura.art>"
# Where order notifications & commission inquiries land
KELLY_NOTIFICATION_EMAIL=contact@kellylaura.art

# --- Cron auth --------------------------------------------------------------
# Vercel Cron requires either a shared secret or no-op. Locally, any value
# works; in production, set to a long random string.
CRON_SECRET=local-dev-cron-secret

# --- Misc -------------------------------------------------------------------
# Sentry stays a no-op when DSN is empty.
SENTRY_DSN=
